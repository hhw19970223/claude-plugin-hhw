{
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/scripts/hook-pre-prompt.js\"",
            "timeout": 5
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/scripts/hook-stop.js\"",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/scripts/hook-watch-notifications.js\"",
            "async": true,
            "asyncRewake": true,
            "rewakeMessage": "[nexscope] 聊天室来新消息:",
            "rewakeSummary": "nexscope 收到新消息"
          }
        ]
      }
    ]
  }
}
